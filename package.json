{
  "name": "electrobun-builder-for-windows",
  "version": "0.1.7",
  "description": "Packaging and signing tool for Electrobun applications on Windows (NSIS, WiX, MSIX).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Catharacta/electrobun-builder.git"
  },
  "bugs": {
    "url": "https://github.com/Catharacta/electrobun-builder/issues"
  },
  "homepage": "https://github.com/Catharacta/electrobun-builder#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "electrobun-builder": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electrobun",
    "builder",
    "windows",
    "installer",
    "nsis",
    "wix",
    "msix"
  ],
  "author": "Electrobun Team",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
